---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ '/' | absolute_url }}</link>
    <language>en</language>
    {% assign feed_entries = site.entries | sort: 'date' | reverse %}
    {% for entry in feed_entries limit: 25 %}
      <item>
        <title>{{ entry.title | xml_escape }}</title>
        <description>{{ entry.description | xml_escape }}</description>
        <pubDate>{{ entry.date | date_to_rfc822 }}</pubDate>
        <link>{{ entry.url | absolute_url }}</link>
        <guid isPermaLink="true">{{ entry.url | absolute_url }}</guid>
        <category>{{ entry.section | xml_escape }}</category>
        {% if entry.audio %}<enclosure url="{{ entry.audio | absolute_url }}" type="audio/mpeg" />{% endif %}
      </item>
    {% endfor %}
  </channel>
</rss>
